{
  "name": "article-zero",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Article Zero — Commonwealth rebuild on Phaser 4. A stealth/horror narrative game about silicate subjectivity, alignment, and the configuration that is still running.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "art": "node scripts/build-atlas.mjs && node scripts/build-unmounted-manifest.mjs",
    "unmounted": "node scripts/build-unmounted-manifest.mjs",
    "moose": "node scripts/import-moose.mjs",
    "pixellab": "node scripts/pixellab-fetch.mjs",
    "pixellab:object": "node scripts/pixellab-fetch-object.mjs",
    "mount:glitch": "bash scripts/mount-glitch-sfx.sh",
    "mount:ui": "bash scripts/mount-ui.sh",
    "mount:vfx": "bash scripts/mount-vfx.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@arwes/react": "^1.0.0-next.25020502",
    "@mlc-ai/web-llm": "^0.2.84",
    "@orama/orama": "^3.1.18",
    "beepbox": "^4.2.0",
    "idb-keyval": "^6.2.5",
    "motion": "^10.18.0",
    "phaser": "^4.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "jimp": "^1.6.1",
    "typescript": "~5.7.2",
    "vite": "^6.0.5",
    "vitest": "^4.1.9"
  }
}
