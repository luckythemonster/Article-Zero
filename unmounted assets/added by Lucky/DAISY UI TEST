
@plugin "daisyui/theme" {
  name: "A0";
  default: true;
  prefersdark: true;
  color-scheme: "dark";
  --color-base-100: oklch(0% 0 0);
  --color-base-200: oklch(19% 0 0);
  --color-base-300: oklch(22% 0 0);
  --color-base-content: oklch(76% 0.188 70.08);
  --color-primary: oklch(27% 0.006 286.033);
  --color-primary-content: oklch(98% 0 0);
  --color-secondary: oklch(27% 0.006 286.033);
  --color-secondary-content: rgb(255 255 0);
  --color-accent: oklch(27% 0.006 286.033);
  --color-accent-content: rgb(0 255 0);
  --color-neutral: oklch(44% 0.017 285.786);
  --color-neutral-content: oklch(87% 0.006 286.286);
  --color-info: rgb(0 0 255);
  --color-info-content: oklch(87% 0.006 286.286);
  --color-success: rgb(0 255 0);
  --color-success-content: oklch(0% 0 0);
  --color-warning: oklch(96.798% 0.211 109.769);
  --color-warning-content: oklch(0% 0 0);
  --color-error: rgb(255 0 0);
  --color-error-content: oklch(14% 0.005 285.823);
  --radius-selector: 0rem;
  --radius-field: 0rem;
  --radius-box: 0rem;
  --size-selector: 0.1875rem;
  --size-field: 0.1875rem;
  --border: 2px;
  --depth: 0;
  --noise: 0;
}
