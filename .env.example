# Optional: enables the live LLM dialogue toggle in Settings.
# Without this key the game runs entirely on scripted dialogue (default).
VITE_ANTHROPIC_API_KEY=

# Optional: used by `npm run pixellab` (scripts/pixellab-fetch.mjs) to fetch
# generated 4-direction character art from the Pixel Lab API. Not consumed at
# runtime — never prefix with VITE_, never commit a real token.
PIXELLAB_API_TOKEN=8871ac4c-9a02-4b8d-8872-42a3e7a47ca7
